# --- App ---
APP_NAME="WB Analytics SaaS"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Security ---
# Сгенерируй: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption key for users' WB API tokens (Fernet) ---
# Сгенерируй: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-fernet-key

# --- PostgreSQL ---
POSTGRES_USER=wb
POSTGRES_PASSWORD=wb
POSTGRES_DB=wb_analytics
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Wildberries API ---
WB_STATISTICS_BASE_URL=https://statistics-api.wildberries.ru

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
